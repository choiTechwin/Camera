{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "CMake Configure Debug",
            "type": "shell",
            "command": "cmake",
            "args": [
                "-S",
                "${workspaceFolder}",
                "-B",
                "${workspaceFolder}/build/Debug",
                "-DCMAKE_BUILD_TYPE=Debug"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": []
        },
        {
            "label": "CMake Build Debug",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "${workspaceFolder}/build/Debug",
                "--config",
                "Debug",
                "-j"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "dependsOn": [
                "CMake Configure Debug"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$gcc"
            ]
        },
        {
            "label": "Run Debug",
            "type": "shell",
            "command": "${workspaceFolder}/.vscode/run-wrapper.sh",
            "args": ["${workspaceFolder}/build/Debug/CameraApp"],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "dependsOn": [
                "CMake Build Debug"
            ],
            "problemMatcher": []
        },
        {
            "label": "CMake Configure Release",
            "type": "shell",
            "command": "cmake",
            "args": [
                "-S",
                "${workspaceFolder}",
                "-B",
                "${workspaceFolder}/build/Release",
                "-DCMAKE_BUILD_TYPE=Release"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": []
        },
        {
            "label": "CMake Build Release",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "${workspaceFolder}/build/Release",
                "--config",
                "Release",
                "-j"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "dependsOn": [
                "CMake Configure Release"
            ],
            "problemMatcher": [
                "$gcc"
            ]
        },
        {
            "label": "Run Release",
            "type": "shell",
            "command": "${workspaceFolder}/.vscode/run-wrapper.sh",
            "args": ["${workspaceFolder}/build/Release/CameraApp"],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "dependsOn": [
                "CMake Build Release"
            ],
            "problemMatcher": []
        }
    ]
}
