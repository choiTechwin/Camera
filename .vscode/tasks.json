{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "CMake: Configure",
      "type": "shell",
      "command": "cmake -S . -B build -DCMAKE_BUILD_TYPE=Debug",
      "group": "build",
      "problemMatcher": ["$gcc"],
      "detail": "Configure CMake project"
    },
    {
      "label": "CMake: Build",
      "type": "shell",
      "command": "cmake --build build --config Debug",
      "group": "build",
      "problemMatcher": ["$gcc"],
      "detail": "Build the CameraApp project"
    }
  ]
}
